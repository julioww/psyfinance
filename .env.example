# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# PostgreSQL connection string — must include ?sslmode=require in production
DATABASE_URL=

# JWT signing secret — must be at least 64 hex characters
# Generate with: npx ts-node scripts/generate-secret.ts
JWT_SECRET=

# Single-user credentials
PSYFINANCE_USERNAME=
# Generate with: npx ts-node scripts/generate-password.ts <your-password>
PSYFINANCE_PASSWORD_HASH=

# Exact origin of the Flutter web app (no trailing slash, no wildcard)
# Example: https://psyfinance.example.com
ALLOWED_ORIGIN=

# Password used to encrypt backup files (store separately from backup files)
BACKUP_PASSWORD=

# Set to 'production' on the live server
NODE_ENV=

# Optional: override the default port (3000)
# PORT=3000
